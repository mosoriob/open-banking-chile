{
  "name": "open-banking-chile",
  "version": "2.0.0",
  "description": "Scrapers open source para bancos chilenos. Obtén tus movimientos y saldo como JSON. Open source scrapers for Chilean banks.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "open-banking-chile": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "sandcastle": "npx tsx .sandcastle/main.ts"
  },
  "keywords": [
    "open-banking",
    "chile",
    "bank-scraper",
    "finanzas",
    "banking",
    "scraper",
    "puppeteer",
    "banco-falabella",
    "banco-chile",
    "santander",
    "bci",
    "banco-estado",
    "movimientos",
    "cartola"
  ],
  "author": "Kai Horwitz <kai@makana.cl>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaihv/open-banking-chile.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "playwright-core": "^1.59.1",
    "puppeteer-core": "^24.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.10.0",
    "@types/node": "^20",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
